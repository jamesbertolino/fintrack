{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "regions": ["gru1"],
  "headers": [
    {
      "source": "/api/webhook/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "functions": {
    "src/app/api/webhook/[userid]/route.ts": {
      "maxDuration": 10
    }
  }
}